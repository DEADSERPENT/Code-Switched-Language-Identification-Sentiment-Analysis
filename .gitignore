# ==============================
# 🔐 Backend (Python)
# ==============================

# Virtual Environment
backend/venv/
.backend/venv/
venv/
.env/

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# ==============================
# ⚛️ Frontend (Node / React / Vite)
# ==============================

# Node modules
frontend/node_modules/
.frontend/node_modules/

# Build output
frontend/dist/
build/

# Vite cache
node_modules/.vite/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==============================
# 🤖 ML Models & Large Files
# ==============================

# Model weights (optional - keep if large)
models/**/*.pt
models/**/*.bin
models/**/*.ckpt

# Training artifacts
models/**/training_history.json

# ==============================
# 📊 Data Files (optional)
# ==============================

# Uncomment if dataset is large
# data/

